# ============================================
# Files to EXCLUDE from GitHub
# These should NEVER be uploaded
# ============================================

# Dependencies (anyone can reinstall these with 'npm install')
node_modules/

# Environment variables (contains your passwords!)
.env

# Uploaded files (user data)
uploads/*
!uploads/.gitkeep

# OS files
Thumbs.db
.DS_Store

# IDE files
.vscode/
.idea/

# Logs
*.log
npm-debug.log*
